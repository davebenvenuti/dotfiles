#!/bin/sh

DOTFILES_PATH="~/.dotfiles"

if [ ! -e ~/.oh-my-zsh ]; then
  echo 'Installing/updating oh-my-zsh...'

  git clone git://github.com/robbyrussell/oh-my-zsh.git ~/.oh-my-zsh
fi

echo 'Symlinking custom zsh theme...'

ln -sf ~/.dotfiles/zsh/dbiddy.zsh-theme ~/.oh-my-zsh/custom/dbiddy.zsh-theme

echo 'Symlinking custom zsh plugins...'

mkdir -p ~/.oh-my-zsh/custom/plugins/kubectl-prompt
ln -sf ~/.dotfiles/zsh/kubectl-prompt.plugin.zsh ~/.oh-my-zsh/custom/plugins/kubectl-prompt/

echo 'Symlinking zshrc...'

ln -sf ~/.dotfiles/zsh/zshrc ~/.zshrc

echo 'Symlinking aliases...'

ln -sf ~/.dotfiles/aliases ~/.aliases

if [ ! -e ~/.rbenv ]; then
  echo 'Installing rbenv...'

  git clone git://github.com/sstephenson/rbenv.git ~/.rbenv
fi

if [ ! -e ~/.rbenv/plugins/ruby-build ]; then
  echo 'Installing rbenv plugin ruby-build...'

  git clone git://github.com/sstephenson/ruby-build.git ~/.rbenv/plugins/ruby-build
fi

if [ ! -e ~/.emacs.d/el-get ]; then
  echo 'Installing el-get (emacs)...'

  git clone git://github.com/dimitri/el-get.git ~/.emacs.d/el-get
fi

echo 'Symlinking emacs.d stuff...'

ln -sf ~/.dotfiles/emacs/init.el ~/.emacs.d/init.el
ln -sf ~/.dotfiles/emacs/modes ~/.emacs.d/modes

echo 'Symlinking git config...'

ln -sf ~/.dotfiles/gitconfig ~/.gitconfig

echo 'Symlinking tmux config...'

ln -sf ~/.dotfiles/tmux.conf ~/.tmux.conf

echo "That's all for now!  You might want to close and reopen the shell"
